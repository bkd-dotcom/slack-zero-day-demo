# Slack App Tokens
# Go to https://api.slack.com/apps, select your app, and navigate to "OAuth & Permissions" to get the Bot Token.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Navigate to "Basic Information" -> "App-Level Tokens" to generate an App Token (must have connections:write scope).
SLACK_APP_TOKEN=xapp-your-app-token-here

# The Slack Channel ID where alerts will be posted. Right-click a channel in Slack -> "View channel details" -> copy the Channel ID.
SLACK_CHANNEL_ID=C0BCP8DPP6X

# GitHub Personal Access Token (with repo scope) for auto-patching PRs.
# Generate at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-token-here

# Google Gemini API Key for AI Threat Analysis.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
