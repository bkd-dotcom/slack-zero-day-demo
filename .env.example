# Slack App Tokens
# Go to https://api.slack.com/apps, select your app, and navigate to "OAuth & Permissions" to get the Bot Token.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Navigate to "Basic Information" -> "App-Level Tokens" to generate an App Token (must have connections:write scope).
SLACK_APP_TOKEN=xapp-your-app-token-here
